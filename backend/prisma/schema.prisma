generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum ExperienceType {
  INDUSTRY
  RESEARCH
}

enum SkillLevel {
  Beginner
  Elementary
  Intermediate
  Advanced
  Expert
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  VIEWER
}

// ── Models ───────────────────────────────────────────────────────────────────

model Profile {
  id               Int      @id @default(1)
  name             String
  email            String
  location         String
  availability     String
  availabilityText String?
  focus            String?
  bio              String[]
  heroHeadline     String?
  heroSubtext      String?
  footerTagline    String?
  yearsExp         String
  publications     Int
  projects         String
  awards           Int
  linkedinUrl      String
  githubUrl        String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Experience {
  id           Int            @id @default(autoincrement())
  title        String
  organization String
  type         ExperienceType
  startDate    String
  endDate      String?
  isCurrent    Boolean        @default(false)
  description  String[]
  technologies String[]
  sortOrder    Int            @default(0)
  isArchived   Boolean        @default(false)
  archivedAt   DateTime?
  deletedAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Education {
  id          Int       @id @default(autoincrement())
  institution String
  degree      String
  field       String
  startYear   Int
  endYear     Int?
  description String?
  sortOrder   Int       @default(0)
  isArchived  Boolean   @default(false)
  archivedAt  DateTime?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Project {
  id           Int       @id @default(autoincrement())
  title        String
  organization String
  year         String
  description  String
  technologies String[]
  featured     Boolean   @default(false)
  iconEmoji    String?
  imageUrl     String?
  githubUrl    String?
  paperUrl     String?
  sortOrder    Int       @default(0)
  isArchived   Boolean   @default(false)
  archivedAt   DateTime?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Publication {
  id          Int       @id @default(autoincrement())
  title       String
  venue       String
  year        Int
  description String
  url         String?
  sortOrder   Int       @default(0)
  isArchived  Boolean   @default(false)
  archivedAt  DateTime?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Skill {
  id          Int        @id @default(autoincrement())
  name        String
  category    String
  proficiency Int
  level       SkillLevel
  sortOrder   Int        @default(0)
  isArchived  Boolean    @default(false)
  archivedAt  DateTime?
  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Certification {
  id         Int       @id @default(autoincrement())
  name       String
  issuer     String
  year       Int?
  url        String?
  sortOrder  Int       @default(0)
  isArchived Boolean   @default(false)
  archivedAt DateTime?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Award {
  id          Int       @id @default(autoincrement())
  title       String
  issuer      String
  year        Int?
  description String?
  badgeText   String
  badgeColor  String?
  sortOrder   Int       @default(0)
  isArchived  Boolean   @default(false)
  archivedAt  DateTime?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String?
  email     String
  subject   String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminUser {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  passwordHash String
  displayName  String
  role         AdminRole @default(ADMIN)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
