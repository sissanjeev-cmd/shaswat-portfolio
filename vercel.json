{
  "rewrites": [
    { "source": "/api/v1/:path*", "destination": "https://shaswat-portfolio-api.vercel.app/api/v1/:path*" },
    { "source": "/about",      "destination": "/about.html" },
    { "source": "/experience", "destination": "/experience.html" },
